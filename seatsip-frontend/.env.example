# Public values only — never commit real secrets.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# Web OAuth client id (Expo invariant). In Google Cloud → that Web client, add Authorized JavaScript origins
# and Authorized redirect URIs matching this app’s URL (e.g. http://localhost:8081 and http://127.0.0.1:8081).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_EAS_PROJECT_ID=
